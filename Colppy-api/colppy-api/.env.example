# ============================================================
# Colppy API - Variables de Entorno
# ============================================================
# Copiá este archivo a .env.local y completá con tus datos.
# NUNCA subas .env.local al repositorio.
# ============================================================

# Usuario de la API (registrado en dev.colppy.com)
COLPPY_API_USER=TuAppColppy

# Password de la API en MD5 (usá toMD5() del helper para generarlo)
COLPPY_API_PASSWORD_MD5=

# Email de tu usuario de Colppy
COLPPY_USER_EMAIL=tu-email@empresa.com

# Password del usuario de Colppy en MD5
COLPPY_USER_PASSWORD_MD5=

# ID de tu empresa en Colppy (lo ves en Colppy > Configuración)
COLPPY_DEFAULT_EMPRESA_ID=

# Ambiente: "production" o "staging"
COLPPY_ENV=production
