      "parameters": {
        "jsCode": "// 1. Obtenemos el objeto principal\nconst item = items[0].json;\n\n// 2. Navegamos por la estructura específica: content -> parts[0] -> text\nlet rawResponse = \"\";\n\nif (item.content && item.content.parts && item.content.parts[0] && item.content.parts[0].text) {\n    rawResponse = item.content.parts[0].text;\n} else {\n    // Backup por si la estructura cambia o viene de otro modo\n    rawResponse = item.text || item.output || (typeof item.content === 'string' ? item.content : \"\");\n}\n\ntry {\n    // 3. Limpieza de Markdown (quitar bloques ```json ... ```)\n    let cleanString = rawResponse\n        .replace(/```json/gi, '') \n        .replace(/```/g, '')      \n        .trim();\n\n    // 4. Parsear el JSON interno\n    const parsedData = JSON.parse(cleanString);\n\n    // 5. Devolvemos el objeto para que n8n vea los campos (fecha, monto, etc.)\n    return [{ json: parsedData }];\n\n} catch (error) {\n    // Si falla el parseo, devolvemos el texto plano para no perder la info\n    return [{ \n        json: { \n            error: \"No se pudo parsear el JSON\",\n            raw_text: rawResponse \n        } \n    }];\n}"
      },
