        "modelId": { "__rl": true, "value": "models/gemini-2.5-pro", "mode": "list" },
        "text": "=Analiza la imagen adjunta del comprobante y devuelve SOLO un JSON valido con las claves:\nfecha (YYYY-MM-DD), numero_comprobante, tipo_comprobante (Factura A/B/C/Ticket/Remito/Nota de Credito/Nota de Debito), moneda (ARS/USD), monto_original (numero, punto decimal), descripcion (max 5 palabras), cuit_emisor (solo digitos), cuit_receptor (solo digitos), razon_social (nombre del emisor), neto_gravado (numero), total_iva (numero).\nSi un campo no esta, devolve null. No uses markdown ni bloques de codigo.",
        "inputType": "binary",
        "binaryPropertyName": "data0",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1,
      "position": [-704, 96],
      "id": "ocr-image",
      "name": "OCR Imagen",
      "credentials": {
        "googlePalmApi": { "id": "ckp67BViTFwefxtq", "name": "Google Gemini(PaLM) Api account" }
      }
    },
    {
      "parameters": {
        "jsCode": "const it = items[0].json;\nlet raw = '';\nif (it.content && it.content.parts && it.content.parts[0] && it.content.parts[0].text) raw = it.content.parts[0].text;\nelse raw = it.text || it.output || (typeof it.content === 'string' ? it.content : JSON.stringify(it));\nlet parsed = {};\nlet ocrOk = true;\ntry {\n  const clean = raw.replace(/```json/gi,'').replace(/```/g,'').trim();\n  parsed = JSON.parse(clean);\n} catch(e) { ocrOk = false; parsed = { _raw: raw }; }\nconst onlyDigits = (v) => (v == null ? '' : String(v).replace(/\\D/g,''));\nconst fmtCuit = (v) => { const d = onlyDigits(v); if (d.length !== 11) return d; return `${d.slice(0,2)}-${d.slice(2,10)}-${d.slice(10)}`; };\nreturn [{ json: {\n  ocr_ok: ocrOk,\n  fecha: parsed.fecha || null,\n  numero_comprobante: parsed.numero_comprobante || null,\n  tipo_comprobante: parsed.tipo_comprobante || null,\n  moneda: (parsed.moneda || 'ARS').toUpperCase(),\n  monto_original: parsed.monto_original != null ? Number(String(parsed.monto_original).replace(/[^0-9.\\-]/g,'')) : 0,\n  descripcion: parsed.descripcion || null,\n  cuit_emisor: fmtCuit(parsed.cuit_emisor),\n  cuit_receptor: fmtCuit(parsed.cuit_receptor),\n  razon_social: parsed.razon_social || parsed['Razon social'] || null,\n  neto_gravado: parsed.neto_gravado != null ? Number(parsed.neto_gravado) : 0,\n  total_iva: parsed.total_iva != null ? Number(parsed.total_iva) : 0\n}}];"
      },
