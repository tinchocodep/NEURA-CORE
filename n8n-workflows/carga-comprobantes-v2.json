    {
      "parameters": {
        "jsCode": "const ocr = $('Parse OCR').first().json;\nconst tenant = items[0].json || {};\nconst inp = $('Edit Fields Inputs').first().json;\nconst rawEmpresa = (tenant.cuit || inp.cuit_empresa || '').toString().replace(/\\D/g,'');\nconst empresaCuit = rawEmpresa.length === 11 ? `${rawEmpresa.slice(0,2)}-${rawEmpresa.slice(2,10)}-${rawEmpresa.slice(10)}` : rawEmpresa;\nconst ce = (ocr.cuit_emisor || '').toString();\nconst cr = (ocr.cuit_receptor || '').toString();\nlet tipo = 'ajeno';\nif (empresaCuit && cr && cr === empresaCuit) tipo = 'compra';\nelse if (empresaCuit && ce && ce === empresaCuit) tipo = 'venta';\nelse if (!empresaCuit) tipo = 'compra';\nreturn [{ json: { ...ocr, empresa_cuit: empresaCuit, tipo, tenant_id: inp.tenant_id, chat_id: inp.chat_id, filename: inp.filename, origen: inp.origen } }];"
      },
