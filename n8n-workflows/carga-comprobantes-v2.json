    {
      "parameters": {
        "jsCode": "const d = $('Decide Tipo').first().json;\nconst tipoDeseado = d.tipo === 'venta' ? 'ingreso' : 'gasto';\nconst cats = items.map(i => i.json).filter(c => c.tipo === tipoDeseado || c.tipo === 'ambos');\nconst listText = cats.map(c => `- ID: ${c.id} | Nombre: ${c.nombre} | Tipo: ${c.tipo}`).join('\\n') || '(sin categorias)';\nreturn [{ json: { categorias_texto: listText, descripcion: d.descripcion, tipo_comprobante: d.tipo_comprobante, cuit_emisor: d.cuit_emisor, monto: d.monto_original, tipo_doc: tipoDeseado } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1984, 32],
