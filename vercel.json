{
    "rewrites": [
        {
            "source": "/api/arca",
            "destination": "https://n8n.neuracall.net/webhook/BuscarPersonas"
        },
        {
            "source": "/api/n8n-comprobantes",
            "destination": "https://n8n.neuracall.net/webhook/CargaDeComprobantes"
        },
        {
            "source": "/api/n8n-send-email",
            "destination": "https://n8n.neuracall.net/webhook/enviar_por_mail"
        },
        {
            "source": "/api/webhook-chatbot",
            "destination": "https://n8n.neuracall.net/webhook/neuracore-chat"
        },
        {
            "source": "/api/n8n-ordenes-pago",
            "destination": "https://n8n.neuracall.net/webhook/ordenes%20de%20pago"
        },
        {
            "source": "/api/afipsdk",
            "destination": "https://app.afipsdk.com/api/v1/automations"
        },
        {
            "source": "/api/afipsdk/:path*",
            "destination": "https://app.afipsdk.com/api/v1/automations/:path*"
        },
        {
            "source": "/presentacion",
            "destination": "/presentacion/index.html"
        },
        {
            "source": "/presentacion-constructora",
            "destination": "/presentacion-constructora/index.html"
        },
        {
            "source": "/((?!presentacion).*)",
            "destination": "/index.html"
        }
    ]
}